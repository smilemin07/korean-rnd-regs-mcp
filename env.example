# korean-rnd-regs-mcp 환경 변수 예시 파일
# 실제 값을 입력한 후 `.env`로 복사하여 사용하세요.
#
# 사용 방법:
#   cp env.example .env
#   # .env 를 텍스트 에디터로 열어 LAW_API_KEY 값 입력

# 국가법령정보센터 OpenAPI 인증값 (OC)
# 발급 절차:
#   1) https://open.law.go.kr 회원가입
#   2) 로그인 후 [오픈API] → [API 사용신청]
#   3) 관리자 승인 대기 (1~3일)
#   4) 이메일로 OC 인증값 수령
LAW_API_KEY=your_law_api_key_here

# (선택) API base URL — 기본값 사용 시 설정 불필요
# LAW_API_URL=https://www.law.go.kr/DRF

# (선택) 로그 레벨 — DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
